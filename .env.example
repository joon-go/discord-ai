# ===========================
# Discord
# ===========================
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
# Comma-separated channel IDs where the bot should respond
SUPPORT_CHANNEL_IDS=123456789012345678,987654321098765432

# ===========================
# Anthropic (Claude)
# ===========================
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-5-20250929
# Fast/cheap model used for intent classification (determines if a message warrants a response)
INTENT_MODEL=claude-haiku-4-5-20251001

# ===========================
# Pylon API
# ===========================
PYLON_API_KEY=your_pylon_api_key
PYLON_BASE_URL=https://api.usepylon.com
# Email address to send ticket notifications FROM (must be configured in Pylon)
PYLON_FROM_EMAIL=support@coderabbit.ai
# Optional: restrict KB ingestion to a specific knowledge base ID
# If not set, internal KBs (slug containing "sop" or "internal") are auto-skipped
# PYLON_KB_ID=2fd942b5-c7d6-4d81-adfe-dd4cba6ecc7f

# ===========================
# RAG / Vector Store (doc site)
# ===========================
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=support_kb

# ===========================
# Doc Site Ingestion
# ===========================
PYLON_KB_URL=https://coderabbit-kb.help.usepylon.com
DOC_SITE_URL=https://docs.coderabbit.ai
MAX_CRAWL_PAGES=200

# Optional: path to local clone of internal docs repo (markdown files only will be ingested)
# GITHUB_REPO_PATH=/path/to/your/repo

# ===========================
# Bot Behavior
# ===========================
RELEVANCE_THRESHOLD=0.3
MAX_HISTORY_TURNS=5
USER_COOLDOWN_MS=3000
# Response verbosity: concise (default) | balanced | detailed
BOT_TONE=concise
